#!/usr/bin/env lua
-- Sketchybar config — entry point for SbarLua-driven setup.
--
-- Sketchybar invokes this file at startup (with $CONFIG_DIR pointing
-- at this directory). The Lua process that this shebang launches is
-- long-lived — `sbar.event_loop()` at the bottom blocks forever and
-- dispatches sketchybar events to the lua handlers registered above.
--
-- Layout under $CONFIG_DIR/lua/:
--   bar.lua             — bar shell + Catppuccin palette + fonts.
--   workspaces.lua      — AeroSpace pills 1..10 with agent-state dot.
--   status/clock.lua    — right-side clock.
--   status/battery.lua  — right-side battery.
--   status/volume.lua   — right-side volume.
--   status/wifi.lua     — right-side wifi.
--   claude_status.lua   — claude_sessions parent + popup, push-driven
--                         from sketchybar-set-state hook events.

package.cpath = package.cpath
  .. ";" .. os.getenv("HOME") .. "/.local/share/sketchybar_lua/?.so"

local CONFIG_DIR = os.getenv("CONFIG_DIR")
  or (os.getenv("HOME") .. "/.config/sketchybar")
package.path = package.path
  .. ";" .. CONFIG_DIR .. "/lua/?.lua"
  .. ";" .. CONFIG_DIR .. "/lua/?/init.lua"

local sbar = require("sketchybar")

-- Bundle the entire initial setup into one IPC round-trip — large
-- speedup for `sketchybar --reload`.
sbar.begin_config()
sbar.hotload(true)

require("bar")
require("workspaces")
require("status.clock")
require("status.battery")
require("status.volume")
require("status.wifi")
require("claude_status")

sbar.end_config()

-- Block forever, dispatching sketchybar events to subscribed lua
-- callbacks. Without this the script exits immediately and no
-- event handlers fire.
sbar.event_loop()
