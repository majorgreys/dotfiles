#!/usr/bin/env bash
# claude-render-sessions — repaint the sketchybar `claude_sessions`
# parent item and rebuild its popup children from per-session JSON
# records under $XDG_STATE_HOME/sketchybar/sessions/.
#
# Invoked as the `script` of the claude_sessions sketchybar item, so it
# runs on initial render and on every claude_agent_state_change.
#
# Popup layout (top-down):
#   AGENTS    N working · M waiting · K idle
#   --- WORKING ---            (only if non-empty)
#     ● <project>  working  <ws>
#     ...
#   --- WAITING ---            (only if non-empty)
#   --- IDLE ---               (only if non-empty)

set -euo pipefail

STATE_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/sketchybar"
SESS_DIR="$STATE_ROOT/sessions"

# Serialise concurrent renders. Two renders racing the
# query-then-remove-then-add sequence can leave stale popup children in
# place when claude_agent_state_change fires multiple times in quick
# succession. `mkdir` is atomic on POSIX filesystems and works on macOS
# (where the `flock` CLI isn't available by default). If a render is
# already in progress we drop this event — the in-flight render reads
# the same on-disk state, so the visual outcome converges.
mkdir -p "$STATE_ROOT"
LOCKDIR="$STATE_ROOT/.render.lock"
if ! mkdir "$LOCKDIR" 2>/dev/null; then
  # Lock older than 30s is stale (crashed render); reclaim it.
  if [ -d "$LOCKDIR" ] && [ "$(find "$LOCKDIR" -maxdepth 0 -mmin +1 2>/dev/null)" ]; then
    rmdir "$LOCKDIR" 2>/dev/null || true
    mkdir "$LOCKDIR" 2>/dev/null || exit 0
  else
    exit 0
  fi
fi
trap 'rmdir "$LOCKDIR" 2>/dev/null || true' EXIT

# Catppuccin palette (must match aerospace.sh + claude.sh).
COLOR_FG="0xffcdd6f4"
COLOR_DIM="0xff7f849c"
COLOR_DIM_DARK="0xff6c7086"
COLOR_GREEN="0xffa6e3a1"
COLOR_YELLOW="0xfff9e2af"

state_word() {
  case "$1" in
    running)         echo "working" ;;
    needs-attention) echo "waiting" ;;
    idle)            echo "idle" ;;
    *)               echo "$1" ;;
  esac
}
state_color() {
  case "$1" in
    running)         echo "$COLOR_GREEN" ;;
    needs-attention) echo "$COLOR_YELLOW" ;;
    idle)            echo "$COLOR_DIM_DARK" ;;
    *)               echo "$COLOR_FG" ;;
  esac
}

sessions_json() {
  shopt -s nullglob
  local files=("$SESS_DIR"/*.json)
  shopt -u nullglob
  if [ "${#files[@]}" -eq 0 ]; then
    echo '[]'
    return
  fi
  jq -s 'map(select(.session_id and .workspace and .state))' "${files[@]}"
}

ALL=$(sessions_json)
COUNT=$(jq 'length' <<< "$ALL")

N_RUN=$(jq   '[.[] | select(.state == "running")]         | length' <<< "$ALL")
N_NEEDS=$(jq '[.[] | select(.state == "needs-attention")] | length' <<< "$ALL")
N_IDLE=$(jq  '[.[] | select(.state == "idle")]            | length' <<< "$ALL")

if [ "$COUNT" -eq 0 ]; then
  PARENT_COLOR="$COLOR_DIM"
elif [ "$N_NEEDS" -gt 0 ]; then
  PARENT_COLOR="$COLOR_YELLOW"
elif [ "$N_RUN" -gt 0 ]; then
  PARENT_COLOR="$COLOR_GREEN"
else
  PARENT_COLOR="$COLOR_FG"
fi

sketchybar --set claude_sessions \
  label="$COUNT" \
  label.color="$PARENT_COLOR"

# Wipe any existing popup children. Filter for "claude_sessions." (note
# trailing dot) so we don't remove the parent itself.
EXISTING=$(sketchybar --query bar 2>/dev/null \
  | jq -r '.items[]? | select(startswith("claude_sessions."))' \
  || true)
if [ -n "$EXISTING" ]; then
  while IFS= read -r name; do
    [ -n "$name" ] && sketchybar --remove "$name"
  done <<< "$EXISTING"
fi

# Header summary row at the top of the popup.
SUMMARY=$(printf '%s working · %s waiting · %s idle' "$N_RUN" "$N_NEEDS" "$N_IDLE")
sketchybar --add item claude_sessions._header popup.claude_sessions \
           --set claude_sessions._header \
                 icon="AGENTS" \
                 icon.font="PragmataPro Mono Liga:Bold:13.0" \
                 icon.color="$COLOR_DIM" \
                 icon.padding_left=12 \
                 icon.padding_right=18 \
                 label="$SUMMARY" \
                 label.color="$COLOR_FG" \
                 label.padding_right=12

SORTED=$(jq -c '
  def state_rank:
    if . == "running" then 0
    elif . == "needs-attention" then 1
    elif . == "idle" then 2
    else 3 end;
  sort_by(
    (.state | state_rank),
    (.workspace | tonumber? // 999),
    -(.updated_at)
  ) | .[]
' <<< "$ALL")

# Compute longest project basename for column alignment in mono font.
MAX_PROJ=0
while IFS= read -r row; do
  [ -z "$row" ] && continue
  PROJ=$(jq -r '.cwd // "" | split("/") | last // "?"' <<< "$row")
  [ -z "$PROJ" ] && PROJ="?"
  L=${#PROJ}
  [ "$L" -gt "$MAX_PROJ" ] && MAX_PROJ=$L
done <<< "$SORTED"

# Emit a section divider before each non-empty state group, then the
# rows for that group.
last_state=""
section_idx=0
while IFS= read -r row; do
  [ -z "$row" ] && continue
  ST=$(jq -r .state <<< "$row")

  if [ "$ST" != "$last_state" ]; then
    section_idx=$((section_idx + 1))
    SECTION_NAME="claude_sessions._sec_$section_idx"
    SECTION_LABEL=$(state_word "$ST" | tr '[:lower:]' '[:upper:]')
    sketchybar --add item "$SECTION_NAME" popup.claude_sessions \
               --set "$SECTION_NAME" \
                     icon="" \
                     label="$SECTION_LABEL" \
                     label.font="PragmataPro Mono Liga:Bold:11.0" \
                     label.color="$COLOR_DIM_DARK" \
                     label.padding_left=12 \
                     label.padding_right=12
    last_state="$ST"
  fi

  SID=$(jq -r .session_id <<< "$row")
  WS=$(jq  -r .workspace  <<< "$row")
  CWD=$(jq -r '.cwd // ""' <<< "$row")

  PROJ=$(printf '%s' "$CWD" | awk -F/ '{print $NF}')
  [ -z "$PROJ" ] && PROJ="?"
  while [ "${#PROJ}" -lt "$MAX_PROJ" ]; do PROJ="$PROJ "; done

  DOT_COLOR=$(state_color "$ST")
  STATE_DISPLAY=$(state_word "$ST")
  while [ "${#STATE_DISPLAY}" -lt 7 ]; do STATE_DISPLAY="$STATE_DISPLAY "; done

  SHORT="${SID:0:8}"
  CHILD="claude_sessions.$SHORT"

  LABEL=$(printf '%s  %s  %s' "$PROJ" "$STATE_DISPLAY" "$WS")

  sketchybar --add item "$CHILD" popup.claude_sessions \
             --set "$CHILD" \
                   icon="●" \
                   icon.color="$DOT_COLOR" \
                   icon.padding_left=12 \
                   icon.padding_right=8 \
                   label="$LABEL" \
                   label.color="$COLOR_FG" \
                   label.padding_right=12 \
                   click_script="aerospace workspace $WS && sketchybar --set claude_sessions popup.drawing=off"
done <<< "$SORTED"
