#!/usr/bin/env bash
# sketchybar-set-state — push agent state into sketchybar.
#
# Usage:
#   sketchybar-set-state <state>
#     state: running | needs-attention | idle | clear
#     stdin (optional): Claude Code hook JSON; .session_id and .cwd are read.
#
# Behavior:
#   1. Read .session_id and .cwd from stdin JSON if present.
#   2. Resolve the session's workspace: if a per-session pin file exists
#      under $STATE_ROOT/sessions/<id>.ws, reuse it; else query AeroSpace
#      for the focused workspace and write the pin.
#   3. Trigger `claude_agent_state_change` with kv args carrying the
#      action, session_id, state, cwd, and workspace. The Lua handler in
#      sketchybar's claude_status module owns the popup + workspace dot
#      from there.
#   4. On state=clear, remove the per-session pin file before triggering.
#
# Logging:
#   One tab-separated line per invocation appended to
#   $STATE_ROOT/helper.log:
#     <ISO time>  <state>  <action>  <sid8>  <ws>  <cwd>
#   `action` is one of: write | clear | skip-no-ws.

set -euo pipefail

STATE="${1:?state required: running|needs-attention|idle|clear}"

STATE_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/sketchybar"
PIN_DIR="$STATE_ROOT/sessions"
LOG_FILE="$STATE_ROOT/helper.log"
mkdir -p "$PIN_DIR"

# Drop legacy .json records from the pre-Lua iteration of this helper.
# Idempotent no-op after first cleanup. Files we still keep: <id>.ws.
for f in "$PIN_DIR"/*; do
  [ -e "$f" ] || continue
  case "$f" in
    *.ws) ;;
    *) rm -f "$f" ;;
  esac
done

HOOK_INPUT=""
if [ ! -t 0 ]; then
  HOOK_INPUT=$(cat || true)
fi

SESSION_ID=""
CWD=""
HOOK_EVENT=""
NOTIF_MSG=""
# Claude inherits the launching shell's env, so $ZMX_SESSION (e.g.
# "d.dotfiles.0") is visible here when claude was started inside a zmx
# session. Empty otherwise.
ZMX_SESSION="${ZMX_SESSION:-}"
if [ -n "$HOOK_INPUT" ] && command -v jq >/dev/null 2>&1; then
  SESSION_ID=$(printf '%s' "$HOOK_INPUT" | jq -r '.session_id // empty' 2>/dev/null || true)
  CWD=$(printf '%s' "$HOOK_INPUT" | jq -r '.cwd // empty' 2>/dev/null || true)
  HOOK_EVENT=$(printf '%s' "$HOOK_INPUT" | jq -r '.hook_event_name // empty' 2>/dev/null || true)
  if [ "$HOOK_EVENT" = "Notification" ]; then
    NOTIF_MSG=$(printf '%s' "$HOOK_INPUT" | jq -r '.message // empty' 2>/dev/null || true)
  fi
fi
SID8="${SESSION_ID:0:8}"

# Resolve the pinned workspace and window-id for this session. Pin
# file is two-line bare text:
#   line 1: aerospace workspace number
#   line 2: aerospace window-id (so click-to-focus targets the exact
#           terminal window, not just the workspace it lives on)
# A one-line legacy pin (workspace only) is upgraded in place.
#
# The window-id is the source of truth — if we have a cached id, ask
# aerospace where that window currently lives and overwrite the pinned
# workspace. This means moving the terminal to another desktop updates
# the popup on the next hook fire.
WS=""
WIN_ID=""
PIN_FILE=""
if [ -n "$SESSION_ID" ]; then
  PIN_FILE="$PIN_DIR/$SESSION_ID.ws"
  if [ -s "$PIN_FILE" ]; then
    WIN_ID=$(sed -n '2p' "$PIN_FILE")
  fi
fi

if [ -n "$WIN_ID" ]; then
  WS=$(aerospace list-windows --all --format '%{window-id} %{workspace}' 2>/dev/null \
    | awk -v wid="$WIN_ID" '$1 == wid { print $2; exit }')
  if [ -z "$WS" ]; then
    # Window-id no longer valid (closed/recreated). Drop it and fall
    # through to the focused-window capture below.
    WIN_ID=""
  fi
fi

if [ -z "$WS" ]; then
  WS=$(aerospace list-workspaces --focused 2>/dev/null || true)
fi
if [ -z "$WIN_ID" ]; then
  WIN_ID=$(aerospace list-windows --focused --format '%{window-id}' 2>/dev/null || true)
fi
if [ -n "$WS" ] && [ -n "$PIN_FILE" ] && [ "$STATE" != "clear" ]; then
  printf '%s\n%s\n' "$WS" "$WIN_ID" > "$PIN_FILE"
fi

log() {
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$(date '+%Y-%m-%d %H:%M:%S')" \
    "$STATE" \
    "${1:--}" \
    "${SID8:--}" \
    "${WS:--}" \
    "${CWD:--}" \
    >> "$LOG_FILE" 2>/dev/null || true
}

if [ -z "$WS" ]; then
  log "skip-no-ws"
  exit 0
fi

if [ "$STATE" = "clear" ]; then
  [ -n "$PIN_FILE" ] && rm -f "$PIN_FILE"
  log "clear"
  sketchybar --trigger claude_agent_state_change \
    "action=clear" \
    "session_id=$SESSION_ID" \
    "workspace=$WS" \
    >/dev/null 2>&1 || true
else
  log "write"
  sketchybar --trigger claude_agent_state_change \
    "action=write" \
    "session_id=$SESSION_ID" \
    "state=$STATE" \
    "workspace=$WS" \
    "window_id=$WIN_ID" \
    "cwd=$CWD" \
    "zmx_session=$ZMX_SESSION" \
    >/dev/null 2>&1 || true
fi

# Notification hook: append to a small jsonl ring buffer the lua side
# reads when rebuilding the popup. Trim to last 100 lines.
NOTIF_FILE="$STATE_ROOT/notifications.jsonl"
if [ "$HOOK_EVENT" = "Notification" ] && [ -n "$NOTIF_MSG" ] && command -v jq >/dev/null 2>&1; then
  NOW=$(date +%s)
  jq -nc \
    --arg sid "$SESSION_ID" \
    --arg cwd "$CWD" \
    --arg msg "$NOTIF_MSG" \
    --arg ws  "$WS" \
    --arg win "$WIN_ID" \
    --arg zmx "$ZMX_SESSION" \
    --argjson ts "$NOW" \
    '{ts:$ts, session_id:$sid, cwd:$cwd, workspace:$ws, window_id:$win, zmx_session:$zmx, message:$msg}' \
    >> "$NOTIF_FILE" 2>/dev/null || true
  if [ -s "$NOTIF_FILE" ]; then
    tail -n 100 "$NOTIF_FILE" > "$NOTIF_FILE.tmp" 2>/dev/null \
      && mv "$NOTIF_FILE.tmp" "$NOTIF_FILE" 2>/dev/null || true
  fi
fi

exit 0
