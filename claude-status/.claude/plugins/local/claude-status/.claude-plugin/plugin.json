{
  "name": "claude-status",
  "version": "1.0.0",
  "description": "Lights up sketchybar workspace pills + dropdown based on Claude Code activity (yellow=running, red=needs-attention).",
  "author": {
    "name": "Tahir Butt"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/sketchybar-set-state running"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/sketchybar-set-state needs-attention"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/sketchybar-set-state needs-attention"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/sketchybar-set-state clear"
          }
        ]
      }
    ]
  }
}
