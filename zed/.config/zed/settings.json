// Zed settings — mirrors helix/.config/helix/config.toml and thbemacs/init.el.
// Docs: https://zed.dev/docs/configuring-zed
{
  // Vim mode (matches evil-mode in thbemacs and Helix's modal editing).
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "on_yank",
    "use_smartcase_find": false
  },

  // Auto-install extensions on startup. The Modus theme ships via this extension.
  "auto_install_extensions": {
    "modus-themes": true
  },

  // Theme — Modus Operandi Tinted (light) / Modus Vivendi Tinted (dark) to match Ghostty.
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },

  // Fonts — PragmataPro Mono Liga 16pt (same as thbemacs and Ghostty).
  "buffer_font_family": "PragmataPro Mono Liga",
  "buffer_font_size": 16,
  "buffer_font_features": { "calt": true },
  "buffer_line_height": "standard",
  "ui_font_family": "PragmataPro Mono Liga",
  "ui_font_size": 14,

  // Editor display — relative line numbers, cursor line, no blink (matches Helix).
  "relative_line_numbers": "enabled",
  "current_line_highlight": "line",
  "cursor_blink": false,
  "show_whitespaces": "selection",
  "soft_wrap": "none",
  "scrollbar": { "show": "auto" },
  "tab_bar": { "show": true },

  // Search — case-sensitive matching disabled (matches helix smart-case = false).
  "search": {
    "case_sensitive": false,
    "whole_word": false,
    "regex": false
  },

  // File picker — show hidden files (matches helix file-picker.hidden = false).
  "file_finder": {
    "include_ignored": "indexed"
  },
  "project_panel": {
    "show_diagnostics": "errors",
    "auto_reveal_entries": false
  },

  // LSP — disable signature-help popup (matches helix auto-signature-help = false).
  "inlay_hints": { "enabled": false },
  "show_signature_help_after_edits": false,

  // Format on save — opt-in per language to mirror helix `auto-format` settings.
  "format_on_save": "off",
  "formatter": "language_server",

  // Auto-revert files changed on disk (matches global-auto-revert-mode).
  "autosave": "off",

  // Telemetry — off, like other personal configs.
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // Terminal — same font/theme as Ghostty.
  "terminal": {
    "font_family": "PragmataPro Mono Liga",
    "font_size": 14,
    "shell": { "program": "/opt/homebrew/bin/fish" },
    "blinking": "off"
  },

  // Languages — keep config terse, mirror helix/.config/helix/languages.toml.
  "languages": {
    "Python": {
      "tab_size": 4,
      "format_on_save": "on",
      "language_servers": ["ruff", "pyright", "!pylsp"],
      "formatter": [
        {
          "language_server": {
            "name": "ruff"
          }
        },
        {
          "code_action": "source.organizeImports.ruff"
        }
      ]
    },
    "Go": {
      "tab_size": 4,
      "hard_tabs": true,
      "format_on_save": "on",
      "formatter": { "language_server": { "name": "gopls" } }
    },
    "Starlark": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": { "external": { "command": "buildifier", "arguments": [] } }
    },
    "YAML": {
      "tab_size": 2,
      "format_on_save": "off",
      "formatter": { "external": { "command": "yamlfmt", "arguments": ["-"] } }
    },
    "JSON": {
      "tab_size": 2
    },
    "TOML": {
      "tab_size": 2
    }
  },

  "lsp": {
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 100,
          "lint": { "run": "onSave" }
        }
      }
    },
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "diagnosticMode": "openFilesOnly",
            "typeCheckingMode": "basic"
          }
        }
      }
    },
    "gopls": {
      "initialization_options": {
        "gofumpt": false,
        "usePlaceholders": true,
        "semanticTokens": true,
        "staticcheck": true,
        "directoryFilters": [
          "-bazel-bin",
          "-bazel-out",
          "-bazel-testlogs",
          "-bazel-mypkg",
          "-bazel-dd-go",
          "-bazel-dd-source"
        ],
        "codelenses": {
          "gc_details": false,
          "generate": false,
          "regenerate_cgo": false,
          "tidy": false,
          "upgrade_dependency": false,
          "vendor": false
        }
      }
    }
  }
}
