// Zed keymap — SPC leader bindings mirror thbemacs/Doom (general.el)
// and helix `space.` workflow. Active in vim normal/visual mode.
// Docs: https://zed.dev/docs/key-bindings
[
  // ─── Global macOS shortcuts (match helix A-y / A-g) ─────────────────────────
  {
    "context": "Editor",
    "bindings": {
      "alt-y": "editor::CopyPath",
      "alt-shift-y": "editor::CopyRelativePath"
    }
  },

  // ─── SPC leader (vim normal/visual mode) ────────────────────────────────────
  {
    "context": "VimControl && !menu && vim_mode != insert",
    "bindings": {
      // SPC . — find file (helix `space .`)
      "space .": "file_finder::Toggle",
      "space space": "file_finder::Toggle",

      // SPC f — files
      "space f f": "file_finder::Toggle",
      "space f r": "projects::OpenRecent",
      "space f s": "workspace::Save",
      "space f S": "workspace::SaveAs",
      "space f y": "editor::CopyPath",
      "space f Y": "editor::CopyRelativePath",
      "space f t": "project_panel::ToggleFocus",

      // SPC b — buffers
      "space b b": "tab_switcher::Toggle",
      "space b d": "pane::CloseActiveItem",
      "space b k": "pane::CloseActiveItem",
      "space b n": "pane::ActivateNextItem",
      "space b p": "pane::ActivatePreviousItem",
      "space b r": "editor::ReloadFile",

      // SPC s — search
      "space s s": "buffer_search::Deploy",
      "space s p": "pane::DeploySearch",
      "space s S": "workspace::NewSearch",
      "space s i": "outline::Toggle",

      // SPC p — project
      "space p p": "projects::OpenRecent",
      "space p f": "file_finder::Toggle",
      "space p s": "pane::DeploySearch",
      "space p b": "tab_switcher::Toggle",
      "space p k": "workspace::CloseAllItemsAndPanes",

      // SPC w — windows / panes
      "space w v": "pane::SplitRight",
      "space w s": "pane::SplitDown",
      "space w d": "pane::CloseActiveItem",
      "space w w": "workspace::ActivateNextPane",
      "space w h": "workspace::ActivatePaneLeft",
      "space w j": "workspace::ActivatePaneDown",
      "space w k": "workspace::ActivatePaneUp",
      "space w l": "workspace::ActivatePaneRight",
      "space w m": "pane::CloseInactiveItems",

      // SPC g — git
      "space g g": "git_panel::ToggleFocus",
      "space g b": "editor::ToggleGitBlame",
      "space g d": "git::Diff",
      "space g s": "git::StageAndNext",

      // SPC c — code
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space c f": "editor::Format",
      "space c d": "editor::GoToDefinition",
      "space c D": "editor::GoToTypeDefinition",
      "space c R": "editor::FindAllReferences",
      "space c h": "editor::Hover",
      "space c x": "diagnostics::Deploy",

      // SPC t — toggles
      "space t l": "editor::ToggleLineNumbers",
      "space t w": "editor::ToggleSoftWrap",
      "space t z": "workspace::ToggleZoom",
      "space t i": "editor::ToggleInlayHints",
      "space t t": "theme_selector::Toggle",

      // SPC h — help
      "space h k": "command_palette::Toggle",
      "space h c": "command_palette::Toggle",
      "space h t": "theme_selector::Toggle",

      // SPC q — quit
      "space q q": "workspace::CloseWindow",

      // SPC o — open
      "space o t": "workspace::ToggleBottomDock",
      "space o p": "project_panel::ToggleFocus",
      "space o T": "workspace::NewTerminal"
    }
  },

  // ─── Tab / pane navigation (match Ghostty cmd+h/j/k/l) ──────────────────────
  {
    "context": "Workspace",
    "bindings": {
      "cmd-h": "workspace::ActivatePaneLeft",
      "cmd-j": "workspace::ActivatePaneDown",
      "cmd-k": "workspace::ActivatePaneUp",
      "cmd-l": "workspace::ActivatePaneRight"
    }
  },

  // ─── Vim normal-mode tweaks (helix-style) ───────────────────────────────────
  {
    "context": "vim_mode == normal",
    "bindings": {
      // Center after half-page scrolls (matches Doom/evil habit).
      "ctrl-d": ["workspace::SendKeystrokes", "ctrl-d z z"],
      "ctrl-u": ["workspace::SendKeystrokes", "ctrl-u z z"]
    }
  }
]
